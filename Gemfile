source "https://rubygems.org"
gem "jekyll", "~> 4.3"
gem "just-the-docs", "~> 0.10"
group :jekyll_plugins do
  gem "jekyll-optional-front-matter"  # md files without front matter still become pages
  gem "jekyll-readme-index"           # README.md serves as site index
  gem "jekyll-relative-links"         # [x](docs/x.md) -> rendered page link
  gem "jekyll-default-layout"
  gem "jekyll-titles-from-headings"
end
